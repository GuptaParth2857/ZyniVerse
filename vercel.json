{
  "buildCommand": "npx prisma generate && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/refresh-schedules",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/refresh-awards",
      "schedule": "0 */4 * * *"
    }
  ]
}
