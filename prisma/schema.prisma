generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  username   String    @unique
  password   String?
  avatar     String?
  bio        String?
  banner     String?
  themeColor String?   @default("emerald")
  signature  String?
  provider   String?
  lastSeen   DateTime?
  createdAt  DateTime  @default(now())

  entries                ListEntry[]
  progress               EpisodeProgress[]
  reviews                Review[]
  dubRequests            DubRequest[]
  posts                  Post[]
  comments               Comment[]
  savedPosts             SavedPost[]
  notifications          Notification[]
  activities             Activity[]
  followers              Follow[]                  @relation("Following")
  following              Follow[]                  @relation("Follower")
  apiKeys                ApiKey[]
  fillerVotes            FillerVote[]
  fillerReports          FillerReport[]
  subscription           Subscription?
  tierLists              TierList[]
  tierListVotes          TierListVote[]
  airingAlerts           AiringAlert[]
  mangaEntries           MangaEntry[]
  watchParties           WatchParty[]              @relation("Host")
  partyMembers           WatchPartyMember[]
  cosplays               Cosplay[]
  cosplayLikes           CosplayLike[]
  challenges             Challenge[]               @relation("Creator")
  challengeParticipants  ChallengeParticipant[]
  challengeEntries       ChallengeEntry[]
  lists                  UserList[]
  listLikes              UserListLike[]
  forumThreads           ForumThread[]
  forumPosts             ForumPost[]
  forumVotes             ForumVote[]
  blogPosts              BlogPost[]
  blogLikes              BlogPostLike[]
  blogComments           BlogComment[]
  userAchievements       UserAchievement[]
  userPoints             UserPoints?
  clubs                  Club[]                    @relation("ClubOwner")
  clubMembers            ClubMember[]              @relation("ClubMembers")
  clubPosts              ClubPost[]                @relation("ClubPosts")
  clubJoinRequests       ClubJoinRequest[]         @relation("ClubJoinRequests")
  wikiEdits              WikiPage[]                @relation("WikiEditor")
  wikiHistory            WikiPageHistory[]         @relation("WikiHistoryEditor")
  conversations          ConversationParticipant[]
  messages               Message[]
  doujinshiEntries       DoujinshiEntry[]
  tagVotes               TagVote[]
  characterVotes         CharacterVote[]
  mangaChapterData       MangaChapterData[]
  polls                  Poll[]
  pollVotes              PollVote[]
  sentFriendRequests     FriendRequest[]           @relation("SentRequests")
  receivedFriendRequests FriendRequest[]           @relation("ReceivedRequests")
  ratings                Rating[]
  communityTags          CommunityTag[]
  tagVotes2              TagVote2[]
  activityReactions      ActivityReaction[]
  clubPostComments       ClubPostComment[]
  clubEventRsvps         ClubEventRSVP[]
  clubBans               ClubBan[]                 @relation("ClubBanned")
  clubBannedBy           ClubBan[]                 @relation("ClubBanner")
  zyniAwardVotes         ZyniAwardVote[]
  figureCollection       FigureCollection[]
  discordAccount         DiscordAccount?
  pageViews              PageView[]
  sessions               UserSession[]
  searchLogs             SearchLog[]
  quizScores             QuizScore[]
  quizChallenger         QuizChallenge[]         @relation("QuizChallenger")
  quizChallengee         QuizChallenge[]         @relation("QuizChallengee")
  dubNotifications       DubNotification[]
  feedbackReplies        FeedbackReply[]
  feedbackLikes          FeedbackLike[]
  feedbackComments       FeedbackComment[]
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model ListEntry {
  id          String    @id @default(cuid())
  userId      String
  mediaId     Int
  type        String
  status      String    @default("PLANNING")
  progress    Int       @default(0)
  total       Int       @default(0)
  score       Int?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@index([userId, status])
  @@index([status])
}

model EpisodeProgress {
  id        String   @id @default(cuid())
  userId    String
  mediaId   Int
  episode   Int
  title     String?
  watchedAt DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId, episode])
  @@index([userId, mediaId])
  @@index([userId, watchedAt])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  mediaId   Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
}

model DubRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaId   Int
  title     String
  language  String
  createdAt DateTime @default(now())

  @@unique([userId, mediaId, language])
  @@index([language])
}

model Post {
  id        String      @id @default(cuid())
  userId    String
  author    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String      @default("POST")
  mediaId   Int?
  rating    Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  savedBy   SavedPost[]
  comments  Comment[]

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  author    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
}

model SavedPost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model Activity {
  id         String   @id @default(cuid())
  userId     String
  type       String
  mediaId    Int?
  mediaTitle String?
  mediaImage String?
  message    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions ActivityReaction[]

  @@index([userId, createdAt])
  @@index([createdAt])
}

// ── API Key Management ──
model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String    @unique
  name      String
  tier      String    @default("free") // free | pro | enterprise
  requests  Int       @default(0) // total requests made
  limit     Int       @default(100) // daily request limit
  lastUsed  DateTime?
  expiresAt DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  usageLogs ApiUsageLog[] @relation("ApiUsageLogs")

  @@index([key])
  @@index([userId])
}

// ── Filler Data Reports ──
model FillerReport {
  id        String   @id @default(cuid())
  mediaId   Int
  episode   Int
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String? // "wrong-type" | "wrong-order" | "spoiler" | "other"
  note      String? // free text explanation
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, mediaId, episode])
  @@index([mediaId, episode])
}

// ── Crowdsourced Filler Verification ──
model FillerVote {
  id        String   @id @default(cuid())
  mediaId   Int
  episode   Int
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vote      String // "canon" | "filler" | "mixed" | "anime-canon"
  createdAt DateTime @default(now())

  @@unique([userId, mediaId, episode])
  @@index([mediaId, episode])
}

// ── Premium Subscriptions (Stripe-ready) ──
model Subscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeId           String?   @unique // Stripe subscription ID
  stripePriceId      String?
  stripeCustomerId   String?
  plan               String    @default("free") // free | pro | enterprise
  status             String    @default("active") // active | canceled | past_due | incomplete
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model TierList {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items TierListItem[]
  votes TierListVote[]

  @@index([userId])
  @@index([isPublic, createdAt])
}

model TierListItem {
  id         String   @id @default(cuid())
  tierListId String
  tier       String
  mediaId    Int
  mediaTitle String
  mediaImage String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  tierList TierList @relation(fields: [tierListId], references: [id], onDelete: Cascade)

  @@unique([tierListId, mediaId])
  @@index([tierListId])
}

model TierListVote {
  id         String   @id @default(cuid())
  tierListId String
  userId     String
  vote       Int
  createdAt  DateTime @default(now())

  tierList TierList @relation(fields: [tierListId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tierListId, userId])
  @@index([tierListId])
}

model WatchParty {
  id          String    @id @default(cuid())
  hostId      String
  mediaId     Int
  mediaTitle  String
  mediaImage  String?
  coverImage  String?
  episode     Int       @default(1)
  status      String    @default("waiting")
  startTime   DateTime?
  videoUrl    String?
  videoType   String?   @default("external")
  isPlaying   Boolean   @default(false)
  playbackPos Float     @default(0)
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  host    User               @relation("Host", fields: [hostId], references: [id], onDelete: Cascade)
  members WatchPartyMember[]

  @@index([status, createdAt])
}

model WatchPartyMember {
  id       String   @id @default(cuid())
  partyId  String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  party WatchParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partyId, userId])
  @@index([partyId])
}

model Poll {
  id          String    @id @default(cuid())
  title       String
  description String?
  createdById String
  isActive    Boolean   @default(true)
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  options   PollOption[]
  votes     PollVote[]

  @@index([isActive, createdAt])
}

model PollOption {
  id     String  @id @default(cuid())
  pollId String
  label  String
  image  String?

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId])
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
}

model Cosplay {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  character   String
  animeTitle  String
  animeId     Int?
  imageUrl    String
  tags        String   @default("")
  likes       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likesRel CosplayLike[]

  @@index([animeId])
  @@index([userId])
  @@index([createdAt])
  @@index([likes])
  @@index([animeTitle, createdAt])
  @@index([character, createdAt])
}

model CosplayLike {
  id        String   @id @default(cuid())
  cosplayId String
  userId    String
  createdAt DateTime @default(now())

  cosplay Cosplay @relation(fields: [cosplayId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cosplayId, userId])
}

// ── API Usage Log ──
model ApiUsageLog {
  id        String   @id @default(cuid())
  keyId     String
  endpoint  String
  status    Int      @default(200)
  ip        String?
  timestamp DateTime @default(now())

  key ApiKey @relation("ApiUsageLogs", fields: [keyId], references: [id], onDelete: Cascade)

  @@index([keyId, timestamp])
  @@index([timestamp])
  @@index([keyId])
}

// ── Forum System ──
model ForumCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  threads ForumThread[]

  @@index([slug])
  @@index([sortOrder])
}

model ForumThread {
  id         String   @id @default(cuid())
  categoryId String?
  animeId    Int?
  animeTitle String?
  animeImage String?
  title      String
  slug       String   @unique
  content    String
  userId     String
  isPinned   Boolean  @default(false)
  isLocked   Boolean  @default(false)
  isDeleted  Boolean  @default(false)
  viewCount  Int      @default(0)
  postCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category ForumCategory? @relation(fields: [categoryId], references: [id])
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts    ForumPost[]
  votes    ForumVote[]

  @@index([categoryId, createdAt])
  @@index([animeId, createdAt])
  @@index([slug])
  @@index([userId])
}

model ForumPost {
  id        String   @id @default(cuid())
  threadId  String
  userId    String
  content   String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes  ForumVote[] @relation("PostVotes")

  @@index([threadId, createdAt])
  @@index([userId])
}

model ForumVote {
  id       String  @id @default(cuid())
  postId   String?
  threadId String?
  userId   String
  vote     Int

  post   ForumPost?   @relation("PostVotes", fields: [postId], references: [id], onDelete: Cascade)
  thread ForumThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@unique([threadId, userId])
}

model AdImpression {
  id        String   @id @default(cuid())
  placement String
  page      String
  userId    String?
  createdAt DateTime @default(now())

  @@index([placement, createdAt])
  @@index([createdAt])
}

model AdClick {
  id        String   @id @default(cuid())
  placement String
  page      String
  userId    String?
  createdAt DateTime @default(now())

  @@index([placement, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // AIRING | FOLLOW | REVIEW | COMMENT | IMPORT | SYSTEM
  title     String
  body      String?
  link      String? // deep link
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model ThemeSong {
  id           String   @id @default(cuid())
  mediaId      Int
  type         String // "OP" or "ED"
  sequence     Int // 1, 2, 3...
  title        String
  artist       String
  composer     String?
  episodeStart Int?
  episodeEnd   Int?
  youtubeId    String?
  createdAt    DateTime @default(now())

  @@unique([mediaId, type, sequence])
  @@index([mediaId])
}

model AnimeEpisode {
  id        String   @id @default(cuid())
  mediaId   Int
  episode   Int
  title     String?
  titleJp   String?
  airdate   String?
  runtime   Int?
  duration  Int?
  createdAt DateTime @default(now())

  @@unique([mediaId, episode])
  @@index([mediaId])
}

model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String // "watch" | "read" | "mixed" | "custom"
  period      String // "yearly" | "seasonal" | "monthly" | "custom"
  year        Int?
  season      String? // "winter" | "spring" | "summer" | "fall"
  startDate   DateTime
  endDate     DateTime
  goalCount   Int // target number of anime/manga
  isPublic    Boolean  @default(true)
  createdBy   String?
  coverImage  String?
  rules       String? // markdown rules text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator      User?                  @relation("Creator", fields: [createdBy], references: [id])
  participants ChallengeParticipant[]
  entries      ChallengeEntry[]

  @@index([type, period, year])
  @@index([isPublic, startDate])
}

model ChallengeParticipant {
  id          String    @id @default(cuid())
  challengeId String
  userId      String
  progress    Int       @default(0) // anime/manga completed so far
  goalCount   Int // personal goal (can override challenge default)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([challengeId])
  @@index([userId])
}

model ChallengeEntry {
  id           String   @id @default(cuid())
  challengeId  String
  userId       String
  mediaId      Int
  mediaTitle   String
  mediaImage   String?
  mediaType    String // "anime" | "manga"
  episodeCount Int? // for anime
  chapterCount Int? // for manga
  completedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId, mediaId])
  @@index([challengeId, userId])
}

model UserList {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  type        String // "anime" | "manga" | "mixed"
  isPublic    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  likes       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    UserListItem[]
  likesRel UserListLike[]

  @@index([userId])
  @@index([isPublic, createdAt])
  @@index([isFeatured])
}

model UserListItem {
  id         String   @id @default(cuid())
  listId     String
  mediaId    Int
  mediaTitle String
  mediaImage String?
  mediaType  String // "anime" | "manga"
  note       String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  list UserList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, mediaId])
  @@index([listId])
}

model UserListLike {
  id        String   @id @default(cuid())
  listId    String
  userId    String
  createdAt DateTime @default(now())

  list UserList @relation(fields: [listId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
}

model Club {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  rules       String?
  coverImage  String?
  icon        String?
  category    String
  isPrivate   Boolean  @default(false)
  ownerId     String
  memberCount Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner        User              @relation("ClubOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      ClubMember[]
  posts        ClubPost[]
  joinRequests ClubJoinRequest[]
  events       ClubEvent[]
  bans         ClubBan[]

  @@index([slug])
  @@index([category, memberCount])
}

model ClubMember {
  id       String   @id @default(cuid())
  clubId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation("ClubMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([clubId])
  @@index([userId])
}

model ClubPost {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  title     String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club     Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user     User              @relation("ClubPosts", fields: [userId], references: [id], onDelete: Cascade)
  comments ClubPostComment[]

  @@index([clubId, createdAt])
}

model ClubJoinRequest {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation("ClubJoinRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
}

model WikiPage {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  content      String
  summary      String?
  category     String
  tags         String   @default("")
  isPublished  Boolean  @default(true)
  version      Int      @default(1)
  lastEditorId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  editor  User              @relation("WikiEditor", fields: [lastEditorId], references: [id])
  history WikiPageHistory[]

  @@index([slug])
  @@index([category])
}

model WikiPageHistory {
  id        String   @id @default(cuid())
  pageId    String
  editorId  String
  version   Int
  title     String
  content   String
  summary   String?
  createdAt DateTime @default(now())

  page   WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  editor User     @relation("WikiHistoryEditor", fields: [editorId], references: [id])

  @@index([pageId, version])
}

// ── Chat / Direct Messages ──
model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model AiringAlert {
  id        String   @id @default(cuid())
  userId    String
  mediaId   Int
  episode   Int
  airingAt  DateTime
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId, episode])
  @@index([userId])
  @@index([airingAt])
}

model MangaEntry {
  id            String    @id @default(cuid())
  userId        String
  mediaId       Int
  title         String
  coverImage    String?
  subType       String    @default("manga") // "manga" | "light_novel" | "manhwa" | "manhua"
  status        String // READING | COMPLETED | PLANNING | DROPPED | PAUSED | REREADING
  chapters      Int       @default(0)
  volumes       Int       @default(0)
  totalChapters Int?
  totalVolumes  Int?
  score         Int?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapterReads MangaChapter[]

  @@unique([userId, mediaId])
  @@index([userId])
  @@index([userId, status])
}

model MangaChapter {
  id        String    @id @default(cuid())
  entryId   String
  chapter   Int
  title     String?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  entry MangaEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, chapter])
  @@index([entryId])
}

// ── Achievements & Badges ──
model Achievement {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String
  icon        String // emoji or SVG path
  category    String // "watching" | "reading" | "community" | "social" | "milestone" | "special"
  criteria    String // JSON describing how to earn it
  points      Int      @default(0)
  isHidden    Boolean  @default(false)
  createdAt   DateTime @default(now())

  awards UserAchievement[]

  @@index([category])
  @@index([code])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())
  progress      Int? // progress toward achievement (0-100)
  metadata      String? // JSON with context (anime title, etc.)

  achievement Achievement @relation(fields: [achievementId], references: [id])
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model UserPoints {
  id        String   @id @default(cuid())
  userId    String   @unique
  points    Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AffiliateClick {
  id        String   @id @default(cuid())
  partner   String
  page      String
  userId    String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([partner, createdAt])
  @@index([createdAt])
}

model BlogPost {
  id          String    @id @default(cuid())
  userId      String
  title       String
  slug        String    @unique
  content     String
  excerpt     String?
  coverImage  String?
  tags        String    @default("")
  isDraft     Boolean   @default(true)
  isDeleted   Boolean   @default(false)
  viewCount   Int       @default(0)
  likeCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes    BlogPostLike[]
  comments BlogComment[]

  @@index([userId, createdAt])
  @@index([isDraft, publishedAt])
  @@index([slug])
}

model BlogPostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model BlogComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model Doujinshi {
  id           String   @id @default(cuid())
  title        String
  circle       String?
  artist       String?
  parody       String?
  tags         String   @default("")
  description  String?
  coverUrl     String?
  pages        Int?
  language     String   @default("japanese")
  isTranslated Boolean  @default(false)
  externalUrl  String?
  addedBy      String?
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entries DoujinshiEntry[]

  @@index([parody])
  @@index([tags])
}

model DoujinshiEntry {
  id          String   @id @default(cuid())
  doujinshiId String
  userId      String
  status      String
  pagesRead   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doujinshi Doujinshi @relation(fields: [doujinshiId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([doujinshiId, userId])
}

model TagVote {
  id        String   @id @default(cuid())
  userId    String
  mediaId   Int
  tag       String
  vote      Int      @default(1)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId, tag])
  @@index([mediaId, tag])
}

model CharacterVote {
  id          String   @id @default(cuid())
  userId      String
  mediaId     Int
  characterId Int
  vote        Int      @default(1)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
  @@index([mediaId, characterId])
}

model MangaChapterData {
  id            String    @id @default(cuid())
  mangaId       Int
  chapterNumber Int
  title         String?
  volume        Int?
  pages         Int?
  publishedAt   DateTime?
  externalId    String?
  createdAt     DateTime  @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  @@unique([mangaId, chapterNumber])
  @@index([mangaId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model Feedback {
  id                  String           @id @default(cuid())
  type                String
  message             String
  page                String?
  email               String?
  userId              String?
  userAgent           String?
  status              String           @default("pending")
  isFeatured          Boolean          @default(false)
  featuredHeading     String?
  featuredDescription String?
  featuredImage       String?
  likeCount           Int              @default(0)
  replyCount          Int              @default(0)
  createdAt           DateTime         @default(now())

  replies  FeedbackReply[]
  likes    FeedbackLike[]
  comments FeedbackComment[]

  @@index([createdAt])
  @@index([type])
  @@index([isFeatured])
}

model FeedbackReply {
  id         String   @id @default(cuid())
  feedbackId String
  userId     String
  message    String
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
}

model FeedbackLike {
  id         String   @id @default(cuid())
  feedbackId String
  userId     String
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([feedbackId, userId])
}

model FeedbackComment {
  id         String   @id @default(cuid())
  feedbackId String
  userId     String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  mediaId   Int?
  query     String?
  genres    String[]
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([mediaId])
}

// ── Feature 1: ZyniVerse Community Score ──
model Rating {
  id         String   @id @default(cuid())
  userId     String
  mediaId    Int
  rating     Float
  weight     Float    @default(1.0)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@index([mediaId])
}

model ZyniScore {
  id            String   @id @default(cuid())
  mediaId       Int      @unique
  weightedScore Float    @default(0)
  bayesianScore Float    @default(0)
  totalVotes    Int      @default(0)
  verifiedVotes Int      @default(0)
  sumRatings    Float    @default(0)
  updatedAt     DateTime @updatedAt
}

// ── Feature 3: Community Tag System ──
model CommunityTag {
  id         String   @id @default(cuid())
  mediaId    Int
  tag        String
  upvotes    Int      @default(0)
  downvotes  Int      @default(0)
  score      Float    @default(0)
  isApproved Boolean  @default(true)
  createdBy  String
  createdAt  DateTime @default(now())

  votes   TagVote2[] @relation("TagVotes")
  creator User       @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([mediaId, tag])
  @@index([mediaId, score])
}

model TagVote2 {
  id             String   @id @default(cuid())
  userId         String
  communityTagId String
  vote           Int
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  communityTag CommunityTag @relation("TagVotes", fields: [communityTagId], references: [id], onDelete: Cascade)

  @@unique([userId, communityTagId])
}

// ── Feature 4: Social Feed Reactions ──
model ActivityReaction {
  id         String   @id @default(cuid())
  userId     String
  activityId String
  type       String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId, type])
  @@index([activityId])
}

// ── Feature 6: Club Enhancements ──
model ClubPostComment {
  id         String   @id @default(cuid())
  clubPostId String
  userId     String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubPost ClubPost @relation(fields: [clubPostId], references: [id], onDelete: Cascade)

  @@index([clubPostId, createdAt])
}

model ClubEvent {
  id          String    @id @default(cuid())
  clubId      String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  isVirtual   Boolean   @default(false)
  streamUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  club    Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  members ClubEventRSVP[]

  @@index([clubId, startTime])
}

model ClubEventRSVP {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  status    String
  createdAt DateTime @default(now())

  event ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model ClubBan {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  bannedBy  String
  reason    String?
  createdAt DateTime @default(now())

  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user   User @relation("ClubBanned", fields: [userId], references: [id], onDelete: Cascade)
  banner User @relation("ClubBanner", fields: [bannedBy], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
}

// ── Feature 8: Discord Integration ──
model DiscordAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  discordId     String   @unique
  username      String
  discriminator String?
  avatar        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Feature 9: ZyniVerse Awards & Bracket Tournaments ──
model ZyniAward {
  id          String   @id @default(cuid())
  year        Int
  category    String
  title       String
  description String?
  status      String   @default("nominating")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nominees ZyniAwardNominee[]
  votes    ZyniAwardVote[]

  @@unique([year, category])
  @@index([year, status])
}

model ZyniAwardNominee {
  id       String  @id @default(cuid())
  awardId  String
  mediaId  Int
  title    String
  image    String?
  round    Int     @default(1)
  seed     Int?
  advanced Boolean @default(false)

  award ZyniAward       @relation(fields: [awardId], references: [id], onDelete: Cascade)
  votes ZyniAwardVote[]

  @@index([awardId, round])
}

model ZyniAwardVote {
  id           String   @id @default(cuid())
  awardId      String
  nomineeId    String
  userId       String
  round        Int      @default(2)
  bracketMatch String?
  createdAt    DateTime @default(now())

  award   ZyniAward        @relation(fields: [awardId], references: [id], onDelete: Cascade)
  nominee ZyniAwardNominee @relation(fields: [nomineeId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([awardId, userId, round])
  @@index([nomineeId])
}

// ── Feature 10: Figure/Merch Collection Tracking ──
model FigureCollection {
  id           String    @id @default(cuid())
  userId       String
  name         String
  anime        String?
  manufacturer String?
  scale        String?
  price        Float?
  currency     String    @default("INR")
  purchaseDate DateTime?
  image        String?
  condition    String    @default("new")
  isForSale    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([anime])
}

// ── Analytics & Retention Infrastructure ──
model PageView {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  path      String
  referrer  String?
  duration  Int?
  userAgent String?
  country   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([path, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model UserSession {
  id             String   @id @default(cuid())
  userId         String?
  sessionId      String   @unique
  startedAt      DateTime @default(now())
  lastActiveAt   DateTime @default(now())
  device         String?
  browser        String?
  os             String?
  country        String?
  pagesViewed    Int      @default(1)
  isActive       Boolean  @default(true)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([sessionId])
  @@index([startedAt])
}

model SearchLog {
  id           String   @id @default(cuid())
  userId       String?
  query        String
  source       String   @default("search")
  resultsCount Int      @default(0)
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([query])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model RetentionMetric {
  id                 String   @id @default(cuid())
  date               DateTime @unique
  dau                Int      @default(0)
  wau                Int      @default(0)
  mau                Int      @default(0)
  newUsers           Int      @default(0)
  returningUsers     Int      @default(0)
  avgSessionMinutes  Float    @default(0)
  avgPagesPerSession Float    @default(0)
  createdAt          DateTime @default(now())

  @@index([date])
}

// ── Quiz Server-Side Persistence ──
model QuizScore {
  id             String   @id @default(cuid())
  userId         String
  category       String
  difficulty     String
  score          Int
  totalQuestions Int
  timeTaken      Int?
  xpEarned       Int      @default(0)
  isDaily        Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([category, score])
  @@index([createdAt])
}

model QuizChallenge {
  id           String   @id @default(cuid())
  challengerId String
  challengeeId String
  category     String
  difficulty   String
  status       String   @default("pending")
  challengerScore Int?
  challengeeScore Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  challenger User @relation("QuizChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  challengee User @relation("QuizChallengee", fields: [challengeeId], references: [id], onDelete: Cascade)

  @@index([challengerId])
  @@index([challengeeId])
  @@index([status])
}

// ── Indian Dub Notifications ──
model DubNotification {
  id             String    @id @default(cuid())
  userId         String
  malId          Int
  language       String
  active         Boolean   @default(true)
  lastNotifiedAt DateTime?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, malId, language])
  @@index([userId])
  @@index([malId, language])
}
