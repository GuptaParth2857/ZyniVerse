generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String?
  avatar    String?
  bio       String?
  banner    String?
  themeColor String?  @default("emerald")
  signature  String?
  provider  String?
  createdAt DateTime @default(now())

  entries               ListEntry[]
  progress              EpisodeProgress[]
  reviews               Review[]
  dubRequests           DubRequest[]
  posts                 Post[]
  comments              Comment[]
  savedPosts            SavedPost[]
  notifications         Notification[]
  activities            Activity[]
  followers             Follow[]               @relation("Following")
  following             Follow[]               @relation("Follower")
  apiKeys               ApiKey[]
  fillerVotes           FillerVote[]
  fillerReports         FillerReport[]
  subscription          Subscription?
  tierLists             TierList[]
  tierListVotes         TierListVote[]
  airingAlerts          AiringAlert[]
  mangaEntries          MangaEntry[]
  watchParties          WatchParty[]           @relation("Host")
  partyMembers          WatchPartyMember[]
  cosplays              Cosplay[]
  cosplayLikes          CosplayLike[]
  challenges            Challenge[]            @relation("Creator")
  challengeParticipants ChallengeParticipant[]
  challengeEntries      ChallengeEntry[]
  lists                 UserList[]
  listLikes             UserListLike[]
  forumThreads          ForumThread[]
  forumPosts            ForumPost[]
  forumVotes            ForumVote[]
  blogPosts             BlogPost[]
  blogLikes             BlogPostLike[]
  blogComments          BlogComment[]
  userAchievements      UserAchievement[]
  userPoints            UserPoints?
  clubs                 Club[]           @relation("ClubOwner")
  clubMembers           ClubMember[]       @relation("ClubMembers")
  clubPosts             ClubPost[]         @relation("ClubPosts")
  clubJoinRequests      ClubJoinRequest[]  @relation("ClubJoinRequests")
  wikiEdits             WikiPage[]         @relation("WikiEditor")
  wikiHistory           WikiPageHistory[]  @relation("WikiHistoryEditor")
  conversations         ConversationParticipant[]
  messages              Message[]
  doujinshiEntries      DoujinshiEntry[]
  tagVotes              TagVote[]
  characterVotes        CharacterVote[]
  mangaChapterData      MangaChapterData[]
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model ListEntry {
  id          String    @id @default(cuid())
  userId      String
  mediaId     Int
  type        String
  status      String    @default("PLANNING")
  progress    Int       @default(0)
  total       Int       @default(0)
  score       Int?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@index([userId, status])
  @@index([status])
}

model EpisodeProgress {
  id        String   @id @default(cuid())
  userId    String
  mediaId   Int
  episode   Int
  title     String?
  watchedAt DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId, episode])
  @@index([userId, mediaId])
  @@index([userId, watchedAt])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  mediaId   Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
}

model DubRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaId   Int
  title     String
  language  String
  createdAt DateTime @default(now())

  @@unique([userId, mediaId, language])
  @@index([language])
}

model Post {
  id        String      @id @default(cuid())
  userId    String
  author    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String      @default("POST")
  mediaId   Int?
  rating    Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  savedBy   SavedPost[]
  comments  Comment[]

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  author    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
}

model SavedPost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model Activity {
  id         String   @id @default(cuid())
  userId     String
  type       String
  mediaId    Int?
  mediaTitle String?
  mediaImage String?
  message    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
}

// ── API Key Management ──
model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String    @unique
  name      String
  tier      String    @default("free") // free | pro | enterprise
  requests  Int       @default(0) // total requests made
  limit     Int       @default(100) // daily request limit
  lastUsed  DateTime?
  expiresAt DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  usageLogs ApiUsageLog[] @relation("ApiUsageLogs")

  @@index([key])
  @@index([userId])
}

// ── Filler Data Reports ──
model FillerReport {
  id        String   @id @default(cuid())
  mediaId   Int
  episode   Int
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String? // "wrong-type" | "wrong-order" | "spoiler" | "other"
  note      String? // free text explanation
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, mediaId, episode])
  @@index([mediaId, episode])
}

// ── Crowdsourced Filler Verification ──
model FillerVote {
  id        String   @id @default(cuid())
  mediaId   Int
  episode   Int
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vote      String // "canon" | "filler" | "mixed" | "anime-canon"
  createdAt DateTime @default(now())

  @@unique([userId, mediaId, episode])
  @@index([mediaId, episode])
}

// ── Premium Subscriptions (Stripe-ready) ──
model Subscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeId           String?   @unique // Stripe subscription ID
  stripePriceId      String?
  stripeCustomerId   String?
  plan               String    @default("free") // free | pro | enterprise
  status             String    @default("active") // active | canceled | past_due | incomplete
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model TierList {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items TierListItem[]
  votes TierListVote[]

  @@index([userId])
  @@index([isPublic, createdAt])
}

model TierListItem {
  id         String   @id @default(cuid())
  tierListId String
  tier       String
  mediaId    Int
  mediaTitle String
  mediaImage String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  tierList TierList @relation(fields: [tierListId], references: [id], onDelete: Cascade)

  @@unique([tierListId, mediaId])
  @@index([tierListId])
}

model TierListVote {
  id         String   @id @default(cuid())
  tierListId String
  userId     String
  vote       Int
  createdAt  DateTime @default(now())

  tierList TierList @relation(fields: [tierListId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tierListId, userId])
  @@index([tierListId])
}

model WatchParty {
  id         String    @id @default(cuid())
  hostId     String
  mediaId    Int
  mediaTitle String
  mediaImage String?
  episode    Int       @default(1)
  status     String    @default("waiting")
  startTime  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  host    User               @relation("Host", fields: [hostId], references: [id], onDelete: Cascade)
  members WatchPartyMember[]

  @@index([status, createdAt])
}

model WatchPartyMember {
  id       String   @id @default(cuid())
  partyId  String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  party WatchParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partyId, userId])
  @@index([partyId])
}

model Cosplay {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  character   String
  animeTitle  String
  animeId     Int?
  imageUrl    String
  tags        String   @default("")
  likes       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likesRel CosplayLike[]

  @@index([animeId])
  @@index([userId])
  @@index([createdAt])
}

model CosplayLike {
  id        String   @id @default(cuid())
  cosplayId String
  userId    String
  createdAt DateTime @default(now())

  cosplay Cosplay @relation(fields: [cosplayId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cosplayId, userId])
}

// ── API Usage Log ──
model ApiUsageLog {
  id        String   @id @default(cuid())
  keyId     String
  endpoint  String
  status    Int      @default(200)
  ip        String?
  timestamp DateTime @default(now())

  key ApiKey @relation("ApiUsageLogs", fields: [keyId], references: [id], onDelete: Cascade)

  @@index([keyId, timestamp])
  @@index([timestamp])
  @@index([keyId])
}

// ── Forum System ──
model ForumCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  threads ForumThread[]

  @@index([slug])
  @@index([sortOrder])
}

model ForumThread {
  id         String   @id @default(cuid())
  categoryId String?
  animeId    Int?
  animeTitle String?
  animeImage String?
  title      String
  slug       String   @unique
  content    String
  userId     String
  isPinned   Boolean  @default(false)
  isLocked   Boolean  @default(false)
  isDeleted  Boolean  @default(false)
  viewCount  Int      @default(0)
  postCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category ForumCategory? @relation(fields: [categoryId], references: [id])
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts    ForumPost[]
  votes    ForumVote[]

  @@index([categoryId, createdAt])
  @@index([animeId, createdAt])
  @@index([slug])
  @@index([userId])
}

model ForumPost {
  id        String   @id @default(cuid())
  threadId  String
  userId    String
  content   String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes  ForumVote[] @relation("PostVotes")

  @@index([threadId, createdAt])
  @@index([userId])
}

model ForumVote {
  id       String  @id @default(cuid())
  postId   String?
  threadId String?
  userId   String
  vote     Int

  post   ForumPost?   @relation("PostVotes", fields: [postId], references: [id], onDelete: Cascade)
  thread ForumThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@unique([threadId, userId])
}

model AdImpression {
  id        String   @id @default(cuid())
  placement String
  page      String
  userId    String?
  createdAt DateTime @default(now())

  @@index([placement, createdAt])
  @@index([createdAt])
}

model AdClick {
  id        String   @id @default(cuid())
  placement String
  page      String
  userId    String?
  createdAt DateTime @default(now())

  @@index([placement, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // AIRING | FOLLOW | REVIEW | COMMENT | IMPORT | SYSTEM
  title     String
  body      String?
  link      String? // deep link
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model ThemeSong {
  id        String @id @default(cuid())
  mediaId   Int
  type      String   // "OP" or "ED"
  sequence  Int      // 1, 2, 3...
  title     String
  artist    String
  composer  String?
  episodeStart Int?
  episodeEnd   Int?
  youtubeId String?
  createdAt DateTime @default(now())

  @@unique([mediaId, type, sequence])
  @@index([mediaId])
}

model AnimeEpisode {
  id        String   @id @default(cuid())
  mediaId   Int
  episode   Int
  title     String?
  titleJp   String?
  airdate   String?
  runtime   Int?
  duration  Int?
  createdAt DateTime @default(now())

  @@unique([mediaId, episode])
  @@index([mediaId])
}

model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String // "watch" | "read" | "mixed" | "custom"
  period      String // "yearly" | "seasonal" | "monthly" | "custom"
  year        Int?
  season      String? // "winter" | "spring" | "summer" | "fall"
  startDate   DateTime
  endDate     DateTime
  goalCount   Int // target number of anime/manga
  isPublic    Boolean  @default(true)
  createdBy   String?
  coverImage  String?
  rules       String? // markdown rules text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator      User?                  @relation("Creator", fields: [createdBy], references: [id])
  participants ChallengeParticipant[]
  entries      ChallengeEntry[]

  @@index([type, period, year])
  @@index([isPublic, startDate])
}

model ChallengeParticipant {
  id          String    @id @default(cuid())
  challengeId String
  userId      String
  progress    Int       @default(0) // anime/manga completed so far
  goalCount   Int // personal goal (can override challenge default)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([challengeId])
  @@index([userId])
}

model ChallengeEntry {
  id           String   @id @default(cuid())
  challengeId  String
  userId       String
  mediaId      Int
  mediaTitle   String
  mediaImage   String?
  mediaType    String // "anime" | "manga"
  episodeCount Int? // for anime
  chapterCount Int? // for manga
  completedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId, mediaId])
  @@index([challengeId, userId])
}

model UserList {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  type        String // "anime" | "manga" | "mixed"
  isPublic    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  likes       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    UserListItem[]
  likesRel UserListLike[]

  @@index([userId])
  @@index([isPublic, createdAt])
  @@index([isFeatured])
}

model UserListItem {
  id         String   @id @default(cuid())
  listId     String
  mediaId    Int
  mediaTitle String
  mediaImage String?
  mediaType  String // "anime" | "manga"
  note       String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  list UserList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, mediaId])
  @@index([listId])
}

model UserListLike {
  id        String   @id @default(cuid())
  listId    String
  userId    String
  createdAt DateTime @default(now())

  list UserList @relation(fields: [listId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
}

model Club {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  coverImage  String?
  icon        String?
  category    String
  isPrivate   Boolean  @default(false)
  ownerId     String
  memberCount Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User          @relation("ClubOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  ClubMember[]
  posts    ClubPost[]
  joinRequests ClubJoinRequest[]

  @@index([slug])
  @@index([category, memberCount])
}

model ClubMember {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation("ClubMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([clubId])
  @@index([userId])
}

model ClubPost {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  title     String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation("ClubPosts", fields: [userId], references: [id], onDelete: Cascade)

  @@index([clubId, createdAt])
}

model ClubJoinRequest {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation("ClubJoinRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
}

model WikiPage {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  summary     String?
  category    String
  tags        String   @default("")
  isPublished Boolean  @default(true)
  version     Int      @default(1)
  lastEditorId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  editor   User            @relation("WikiEditor", fields: [lastEditorId], references: [id])
  history  WikiPageHistory[]

  @@index([slug])
  @@index([category])
}

model WikiPageHistory {
  id        String   @id @default(cuid())
  pageId    String
  editorId  String
  version   Int
  title     String
  content   String
  summary   String?
  createdAt DateTime @default(now())

  page   WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  editor User     @relation("WikiHistoryEditor", fields: [editorId], references: [id])

  @@index([pageId, version])
}

// ── Chat / Direct Messages ──
model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model AiringAlert {
  id        String   @id @default(cuid())
  userId    String
  mediaId   Int
  episode   Int
  airingAt  DateTime
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId, episode])
  @@index([userId])
  @@index([airingAt])
}

model MangaEntry {
  id            String    @id @default(cuid())
  userId        String
  mediaId       Int
  title         String
  coverImage    String?
  subType       String    @default("manga") // "manga" | "light_novel" | "manhwa" | "manhua"
  status        String // READING | COMPLETED | PLANNING | DROPPED | PAUSED | REREADING
  chapters      Int       @default(0)
  volumes       Int       @default(0)
  totalChapters Int?
  totalVolumes  Int?
  score         Int?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapterReads MangaChapter[]

  @@unique([userId, mediaId])
  @@index([userId])
  @@index([userId, status])
}

model MangaChapter {
  id        String    @id @default(cuid())
  entryId   String
  chapter   Int
  title     String?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  entry MangaEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, chapter])
  @@index([entryId])
}

// ── Achievements & Badges ──
model Achievement {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String
  icon        String   // emoji or SVG path
  category    String   // "watching" | "reading" | "community" | "social" | "milestone" | "special"
  criteria    String   // JSON describing how to earn it
  points      Int      @default(0)
  isHidden    Boolean  @default(false)
  createdAt   DateTime @default(now())

  awards UserAchievement[]

  @@index([category])
  @@index([code])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())
  progress      Int?     // progress toward achievement (0-100)
  metadata      String?  // JSON with context (anime title, etc.)

  achievement Achievement @relation(fields: [achievementId], references: [id])
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model UserPoints {
  id        String   @id @default(cuid())
  userId    String   @unique
  points    Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AffiliateClick {
  id        String   @id @default(cuid())
  partner   String
  page      String
  userId    String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([partner, createdAt])
  @@index([createdAt])
}

model BlogPost {
  id          String    @id @default(cuid())
  userId      String
  title       String
  slug        String    @unique
  content     String
  excerpt     String?
  coverImage  String?
  tags        String    @default("")
  isDraft     Boolean   @default(true)
  isDeleted   Boolean   @default(false)
  viewCount   Int       @default(0)
  likeCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes    BlogPostLike[]
  comments BlogComment[]

  @@index([userId, createdAt])
  @@index([isDraft, publishedAt])
  @@index([slug])
}

model BlogPostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model BlogComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model Doujinshi {
  id           String   @id @default(cuid())
  title        String
  circle       String?
  artist       String?
  parody       String?
  tags         String   @default("")
  description  String?
  coverUrl     String?
  pages        Int?
  language     String   @default("japanese")
  isTranslated Boolean  @default(false)
  externalUrl  String?
  addedBy      String?
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entries DoujinshiEntry[]

  @@index([parody])
  @@index([tags])
}

model DoujinshiEntry {
  id           String   @id @default(cuid())
  doujinshiId  String
  userId       String
  status       String
  pagesRead    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  doujinshi Doujinshi @relation(fields: [doujinshiId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([doujinshiId, userId])
}

model TagVote {
  id        String   @id @default(cuid())
  userId    String
  mediaId   Int
  tag       String
  vote      Int      @default(1)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId, tag])
  @@index([mediaId, tag])
}

model CharacterVote {
  id          String   @id @default(cuid())
  userId      String
  mediaId     Int
  characterId Int
  vote        Int      @default(1)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
  @@index([mediaId, characterId])
}

model MangaChapterData {
  id            String    @id @default(cuid())
  mangaId       Int
  chapterNumber Int
  title         String?
  volume        Int?
  pages         Int?
  publishedAt   DateTime?
  externalId    String?
  createdAt     DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id])
  userId String?

  @@unique([mangaId, chapterNumber])
  @@index([mangaId])
}
